{
  "kind": "collectionType",
  "collectionName": "face_queues",
  "info": {
    "name": "Face Queue",
    "description": ""
  },
  "options": {
    "increments": true,
    "timestamps": true,
    "draftAndPublish": false
  },
  "attributes": {
    "emitted_invoice": {
      "model": "emitted-invoice"
    },
    "mode": {
      "type": "enumeration",
      "enum": [
        "test",
        "real"
      ]
    },
    "request_url": {
      "type": "string"
    },
    "request_body": {
      "type": "text"
    },
    "response_body": {
      "type": "text"
    },
    "response_code": {
      "type": "integer"
    },
    "status": {
      "type": "enumeration",
      "enum": [
        "pending",
        "registered",
        "delivered",
        "rejected",
        "error"
      ]
    },
    "invoice": {
      "type": "json"
    },
    "registration_number": {
      "type": "string"
    },
    "last_status_check": {
      "type": "datetime"
    },
    "attempts": {
      "type": "integer",
      "default": 0
    }
  }
}
